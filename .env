# .env.example — copy to .env and fill in values for local development
# .env is gitignored; never commit secrets.

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "false" to disable a feature at runtime (default: all enabled)
ENABLE_QUALITY_CHECK=true
ENABLE_AI_MODE=true
ENABLE_VIDEO_EXPORT=true

# ── Azure Speech ──────────────────────────────────────────────────────────────
# The Cognitive Services / AI Foundry resource name used for TTS and STT.
# Speech tokens are obtained via AAD (DefaultAzureCredential) — no key required.
AZURE_SPEECH_RESOURCE_NAME=bhs-development-public-foundry-r
AZURE_SPEECH_REGION=eastus2
# "standard" = regional Speech Service | "mai" = MAI-Voice-1 via Foundry endpoint
AZURE_TTS_MODE=mai
AZURE_VOICE_ENDPOINT=https://cwoodland-project-eastu-resource.cognitiveservices.azure.com

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Required for AI presentation generation (ai_mode=true).
AZURE_OPENAI_ENDPOINT=https://bhs-development-public-foundry-r.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_IMAGE_ENDPOINT=https://cwoodland-project-eastu-resource.services.ai.azure.com
AZURE_IMAGE_DEPLOYMENT=MAI-Image-2e

# ── Azure Document Intelligence (optional) ────────────────────────────────────
# Used by PptxScriptParserService for OCR fallback. Leave blank to skip.
AZURE_DOC_INTEL_ENDPOINT=
# ── Application Insights (optional) ──────────────────────────────────────────────
# Set to enable structured telemetry. Leave blank to run without.
APPLICATIONINSIGHTS_CONNECTION_STRING=
# ── UI ────────────────────────────────────────────────────────────────────────
# Optional banner shown at the top of the app (e.g. "Public environment — no sensitive data").
APP_BANNER_MESSAGE=

# ── Identity (local Docker dev only) ──────────────────────────────────────
# When running in a container locally (run-docker.ps1), DefaultAzureCredential
# uses a service principal (client secret) because the Windows DPAPI-encrypted
# az-login token cache cannot be read by Linux containers.
#
# Create a service principal:
#   az ad sp create-for-rbac --name pptx-narrator-local --skip-assignment
# Then grant it "Cognitive Services User" on your Speech/OpenAI resource.
#
# In production on Azure Container Apps, leave all three blank — Managed Identity is used.
AZURE_TENANT_ID=16b3c013-d300-468d-ac64-7eda0820b6d3
AZURE_CLIENT_ID=98e8135d-5ca5-4015-b0ac-825ae189de20
AZURE_CLIENT_SECRET=oz.8Q~LCdlgKw4Q4elxuE~GvNHHojJvtQUNKUduC
