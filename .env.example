# .env.example — copy to .env and fill in values for local development
# .env is gitignored; never commit secrets.

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "false" to disable a feature at runtime (default: all disabled)
ENABLE_QUALITY_CHECK=false
ENABLE_AI_MODE=false
ENABLE_VIDEO_EXPORT=false
ENABLE_MP3_EXPORT=true

# When true, the "Use slide text as narration" toggle defaults to on.
# Upload a single PPTX — each slide's text becomes the narration script.
DEFAULT_SINGLE_PPTX_MODE=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend API.
# Use '*' for local dev. In production, set to the frontend Container App URL.
CORS_ALLOWED_ORIGINS=*

# ── Azure Speech ──────────────────────────────────────────────────────────────
# The Cognitive Services / AI Foundry resource name used for TTS and STT.
# Speech tokens are obtained via AAD (DefaultAzureCredential) — no key required.
AZURE_SPEECH_RESOURCE_NAME=bhs-development-public-foundry-r
AZURE_SPEECH_REGION=eastus2

# TTS mode:
#   "standard" = regional Azure Speech Service (default).
#   "mai"      = Azure AI Foundry MAI-Voice-1 endpoint (set AZURE_VOICE_ENDPOINT).
AZURE_TTS_MODE=standard

# Max number of slides to synthesize concurrently.
# Start with 3-4. Higher values may improve throughput but can increase 429 throttling.
AZURE_TTS_MAX_PARALLELISM=4

# Base URL of the Foundry resource for MAI Voice. Only used when AZURE_TTS_MODE=mai.
AZURE_VOICE_ENDPOINT=

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Required for AI presentation generation (ai_mode=true).
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
# Separate endpoint for image generation (MAI model on services.ai.azure.com)
AZURE_IMAGE_ENDPOINT=https://YOUR_MAI_RESOURCE.services.ai.azure.com
AZURE_IMAGE_DEPLOYMENT=MAI-Image-2e

# ── Azure Document Intelligence (optional) ────────────────────────────────────
# Used by PptxScriptParserService for OCR fallback. Leave blank to skip.
AZURE_DOC_INTEL_ENDPOINT=

# ── Application Insights (optional) ──────────────────────────────────────────
# Set to enable structured telemetry. Leave blank to run without.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── UI Branding Storage ───────────────────────────────────────────────────────
# Production (ACA): set to the storage account name created by Bicep.
#   The backend managed identity is granted Storage Blob Data Contributor
#   automatically at deploy time.
# Local dev: leave blank to fall back to a local ui-branding.json file.
AZURE_BRANDING_STORAGE_ACCOUNT=
AZURE_BRANDING_CONTAINER=branding-data

# ── UI ────────────────────────────────────────────────────────────────────────
# Optional banner shown at the top of the app (e.g. "Public environment — no sensitive data").
APP_BANNER_MESSAGE=
# Optional helper text shown in Step 1 under "Upload your files".
UPLOAD_FILES_MESSAGE=Provide a narration script and (optionally) a PowerPoint to narrate.

# ── Identity ──────────────────────────────────────────────────────────────────
# AZURE_TENANT_ID pins DefaultAzureCredential to the correct tenant in every
# environment (native dev, Docker, ACA) and is the only identity setting most
# users need to touch.
#
# AZURE_CLIENT_ID / AZURE_CLIENT_SECRET are LOCAL DOCKER ONLY, and even then
# only useful in tenants that do NOT enforce a Conditional Access "compliant
# device" policy:
#
#   * Native dev (run.ps1 / run.sh)  -> leave both blank, your host az login is used
#   * Production (Container Apps)    -> leave both blank, Managed Identity is used
#   * Local Docker (run-docker.ps1) on a CA-restricted tenant (e.g. the default
#     Microsoft Non-Production tenant) -> Docker is NOT supported for local Azure
#     auth. Use native dev instead. See README "Running with Docker Compose".
#   * Local Docker (run-docker.ps1) on an unrestricted tenant -> set both to a
#     service principal that has Cognitive Services User on your AI resource:
#         az ad sp create-for-rbac --name pptx-narrator-local --skip-assignment
AZURE_TENANT_ID=16b3c013-d300-468d-ac64-7eda0820b6d3
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Build-time API base URL baked into the Vite bundle. Leave blank for local dev
# (the Vite proxy and Nginx forward /api/* to the backend).
# Set in CI/CD when building the production frontend image, e.g.
#   VITE_API_URL=https://narrator-prod-backend.<region>.azurecontainerapps.io
VITE_API_URL=

# Runtime backend URL used by the Nginx container to proxy /api/* requests.
# In docker-compose this defaults to http://backend:8080. In Container Apps it
# is set automatically by scripts/deploy.ps1 to the deployed backend FQDN.
BACKEND_URL=http://backend:8080
