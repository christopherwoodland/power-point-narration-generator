    },
    "containerAppsEnvironmentId": {
      "type": "string"
    },
    "containerRegistryName": {
      "type": "string"
    },
    "backendImage": {
      "type": "string"
    },
    "enableQualityCheck": {
      "type": "bool"
    },
    "enableAiMode": {
      "type": "bool"
    },
    "enableVideoExport": {
