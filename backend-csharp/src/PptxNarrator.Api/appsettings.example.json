{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "App": {
    "EnableQualityCheck": false,
    "EnableAiMode": false,
    "EnableVideoExport": false,
    "EnableMp3Export": true,

    "AzureSpeechResourceName": "YOUR_SPEECH_RESOURCE_NAME",
    "AzureSpeechRegion": "eastus2",
    "AzureTtsMode": "standard",
    "TtsMaxParallelism": 4,
    "AzureVoiceEndpoint": "",

    "AzureOpenAiEndpoint": "https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com",
    "AzureOpenAiDeployment": "gpt-4o",
    "AzureImageEndpoint": "https://YOUR_MAI_RESOURCE.services.ai.azure.com",
    "AzureImageDeployment": "MAI-Image-2e",
    "ChatApiVersion": "2025-01-01-preview",
    "ImageApiVersion": "2024-02-01",

    "AzureDocIntelEndpoint": "https://YOUR_RESOURCE_NAME.cognitiveservices.azure.com/",

    "BrandingStorageAccountName": "",
    "BrandingStorageContainer": "branding-data",

    "DefaultSinglePptxMode": false,
    "AppBannerMessage": "",
    "UploadFilesMessage": "Provide a narration script and (optionally) a PowerPoint to narrate."
  }
}
